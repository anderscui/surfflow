{
  "manifest_version": 3,
  "name": "SurfFlow",
  "version": "0.1.1",
  "description": "Stream web data seamlessly into your local repo.",
  "permissions": ["activeTab", "tabs", "menus", "scripting", "history"],
  "host_permissions": [
    "*://*.douban.com/*",

    "https://www.amazon.com/*",
    "https://www.amazon.co.uk/*",
    "https://www.amazon.co.jp/*",

    "http://127.0.0.1:8000/*",
    "http://localhost:8000/*"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "scripts": ["background.js"],
    "type": "module"
  }
}
