{
  "manifest_version": 3,
  "name": "SurfFlow",
  "version": "0.1.1",
  "description": "Stream web data seamlessly into your local repo.",
  "permissions": ["activeTab", "tabs", "scripting", "history"],
  "host_permissions": [
    "*://*.douban.com/*",
    "http://127.0.0.1:8000/*",
    "http://localhost:8000/*"
  ],
  "action": {
    "default_popup": "popup.html"
  }
}
